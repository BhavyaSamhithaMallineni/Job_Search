# Anthropic API (for resume tailoring + outreach drafts)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# RapidAPI - LinkedIn Jobs Search
# Get at: https://rapidapi.com/jaypat87/api/linkedin-jobs-search
RAPIDAPI_KEY=your_rapidapi_key_here

# ScraperAPI - for H1BData.info scraping
# Get at: https://www.scraperapi.com (free tier: 1000 calls/month)
SCRAPER_API_KEY=your_scraper_api_key_here

# Optional: LinkedIn session cookie for post searching (not for applying)
# Get by: Login to LinkedIn → F12 → Application → Cookies → li_at value
# This is READ ONLY - used only to search posts, never to apply or DM
LINKEDIN_SESSION_COOKIE=optional_li_at_cookie_here
